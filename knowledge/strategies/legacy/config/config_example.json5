{
  // ==================== BobQuant 配置示例 v3.0 ====================
  // 此文件使用 JSON5 格式，支持：
  // - 注释（// 和 /* */）
  // - 尾随逗号
  // - 环境变量替换 ${VAR_NAME}
  
  // ==================== 系统配置 ====================
  "system": {
    "name": "BobQuant 模拟盘",
    "version": "3.0",           // 当前配置版本
    "mode": "simulation",        // simulation / real / backtest
    "log_level": "INFO",
    "debug": false
  },
  
  // ==================== 账户配置 ====================
  "account": {
    "initial_capital": 1000000,  // 初始资金 100 万
    "commission_rate": 0.0005,   // 佣金万分之五
    "stamp_duty_rate": 0.001,    // 印花税千分之一
    "max_position_pct": 0.10,    // 单票最大仓位 10%
    "max_stocks": 10,            // 最大持仓 10 只
    
    // SecretRef 示例 - 从环境变量读取 API 密钥
    "api_key": "${env:BOBQUANT_API_KEY}",
    "api_secret": "${file:~/.bobquant/secret.txt}"
  },
  
  // ==================== 策略配置 ====================
  "strategy": {
    // 双 MACD 策略
    "dual_macd": {
      "enabled": true,
      "short_period": [6, 13, 5],   // 短周期 (fast, slow, signal)
      "long_period": [24, 52, 18]   // 长周期
    },
    
    // 布林带策略
    "bollinger": {
      "enabled": true,
      "window": 20,
      "num_std": 2,
      "dynamic": true               // 动态标准差
    },
    
    // 信号过滤
    "signal": {
      "rsi_buy_max": 35,
      "rsi_sell_min": 70,
      "volume_confirm": true,
      "volume_ratio_buy": 1.5
    },
    
    // 金字塔加仓
    "pyramid": {
      "enabled": true,
      "levels": [0.03, 0.05, 0.07],  // 下跌 3%/5%/7% 加仓
      "add_dip_pct": 0.03            // 加仓间隔 3%
    }
  },
  
  // ==================== 仓位管理 ====================
  "position": {
    "max_position_pct": 0.10,    // 单票最大仓位 10%
    "max_stocks": 10,            // 最大同时持仓 10 只
    "min_buy_shares": 100,       // 最小买入 100 股
    "pyramid": {
      "enabled": true,
      "levels": [0.03, 0.05, 0.07],
      "add_dip_pct": 0.03
    }
  },
  
  // ==================== 风控配置 ====================
  "risk_control": {
    // 硬止损
    "stop_loss": {
      "enabled": true,
      "pct": -0.08              // -8% 止损
    },
    
    // 跟踪止损
    "trailing_stop": {
      "enabled": true,
      "activation_pct": 0.05,   // 盈利 5% 后激活
      "drawdown_pct": 0.02      // 回撤 2% 止盈
    },
    
    // 分批止盈
    "take_profit": {
      "enabled": true,
      "levels": [
        {"threshold": 0.05, "sell_ratio": 0.33},   // 盈利 5% 卖出 33%
        {"threshold": 0.10, "sell_ratio": 0.50},   // 盈利 10% 卖出 50%
        {"threshold": 0.15, "sell_ratio": 1.00}    // 盈利 15% 清仓
      ]
    }
  },
  
  // ==================== 大盘风控 ====================
  "market_risk": {
    "enabled": true,
    "index_code": "sh.000001",   // 上证指数
    "ma20_line": 20,
    "max_position_bear": 0.50,   // 跌破 20 日线仓位≤50%
    "crash_threshold": -0.03     // 暴跌 -3% 禁止买入
  },
  
  // ==================== 数据源 ====================
  "data": {
    "primary": "tencent",         // 腾讯财经
    "fallback": "tencent",
    "history_provider": "baostock",
    "history_days": 60
  },
  
  // ==================== 交易时段 ====================
  "trading_hours": {
    "morning_start": "09:25",
    "morning_end": "11:35",
    "afternoon_start": "12:55",
    "afternoon_end": "15:05",
    "pre_market": "09:15",        // 盘前准备
    "post_market": "15:30"        // 盘后总结
  },
  
  // ==================== TWAP 算法执行 ====================
  "twap": {
    "enabled": false,             // 是否启用 TWAP
    "threshold": 10000,           // 触发 TWAP 的股数阈值
    "slices": 5,                  // 拆分份数
    "duration_minutes": 10        // 执行时长（分钟）
  },
  
  // ==================== 强化学习 (RL) ====================
  "rl": {
    "enabled": false,             // 是否启用 RL
    "algorithm": "ppo",           // ppo / a2c / dqn
    "model_path": "rl/models",
    
    "training": {
      "total_timesteps": 10000,
      "eval_freq": 1000,
      "n_eval_episodes": 5,
      "window_size": 60
    },
    
    "trading": {
      "max_stocks": 10,
      "max_position_pct": 0.10,
      "initial_capital": 1000000
    },
    
    "prediction": {
      "use_trained_model": true,
      "deterministic": true
    }
  },
  
  // ==================== 通知配置 ====================
  "notify": {
    "feishu": {
      "enabled": true,
      "user_id": "ou_973651ccbc692b7cd90a7d561f6885b3",
      // SecretRef 示例 - 从环境变量读取 Webhook URL
      "webhook_url": "${env:FEISHU_WEBHOOK_URL}"
    },
    "events": {
      "trade_executed": true,     // 交易执行
      "stop_loss": true,          // 止损触发
      "take_profit": true,        // 止盈触发
      "daily_report": true,       // 日报
      "risk_warning": true        // 风险预警
    }
  },
  
  // ==================== 日志配置 ====================
  "log": {
    "dir": "logs/sim_trading",
    "max_size": 10485760,         // 10MB
    "backup_count": 10
  },
  
  // ==================== 自动调仓 (Rebalance) ====================
  "rebalance": {
    "enabled": false,
    "mode": "equal_weight",       // equal_weight / target_weight
    "frequency": "weekly",        // daily / weekly / monthly
    "rebalance_day": 0,           // 周一 (0-6)
    "threshold_pct": 0.05,        // 偏离 5% 触发
    "min_trade_value": 1000,      // 最小交易金额
    "commission_rate": 0.0005,
    "stamp_duty_rate": 0.001,
    "slippage": 0.001,
    "max_position_pct": 0.10,
    "min_position_pct": 0.02,
    "respect_t1": true,           // 遵守 T+1
    "notify_enabled": true
  },
  
  // ==================== 股票池 ====================
  "stock_pool": [
    {"code": "sh.600000", "name": "浦发银行", "strategy": "bollinger"},
    {"code": "sh.600036", "name": "招商银行", "strategy": "dual_macd"},
    {"code": "sz.000001", "name": "平安银行", "strategy": "bollinger"},
    {"code": "sh.600030", "name": "中信证券", "strategy": "dual_macd"},
    {"code": "sz.000002", "name": "万科 A", "strategy": "bollinger"}
    // 更多股票...
  ],
  
  // ==================== 5 层配置继承 ====================
  // 优先级：Per-Group > Per-Account > Per-Channel > Per-Strategy > Global Defaults
  
  // 第 1 层：全局默认配置
  "global_defaults": {
    "account": {
      "initial_capital": 1000000,
      "commission_rate": 0.0005
    },
    "position": {
      "max_position_pct": 0.10,
      "max_stocks": 10
    }
  },
  
  // 第 2 层：策略级配置
  "strategy_configs": {
    "bollinger_conservative": {
      "strategy_name": "bollinger_conservative",
      "position": {
        "max_position_pct": 0.05    // 保守策略：单票最大 5%
      },
      "risk_control": {
        "stop_loss": {
          "pct": -0.05              // 保守策略：-5% 止损
        }
      }
    },
    "dual_macd_aggressive": {
      "strategy_name": "dual_macd_aggressive",
      "position": {
        "max_position_pct": 0.15    // 激进策略：单票最大 15%
      },
      "risk_control": {
        "stop_loss": {
          "pct": -0.10              // 激进策略：-10% 止损
        }
      }
    }
  },
  
  // 第 3 层：渠道级配置
  "channel_configs": {
    "sim_channel": {
      "channel": "sim_channel",
      "system": {
        "mode": "simulation",       // 模拟盘模式
        "log_level": "DEBUG"
      }
    },
    "real_channel": {
      "channel": "real_channel",
      "system": {
        "mode": "real",             // 实盘模式
        "log_level": "INFO"
      }
    }
  },
  
  // 第 4 层：账户级配置
  "account_configs": {
    "account_001": {
      "account_id": "account_001",
      "account": {
        "initial_capital": 500000   // 此账户初始资金 50 万
      }
    },
    "account_002": {
      "account_id": "account_002",
      "account": {
        "initial_capital": 2000000  // 此账户初始资金 200 万
      }
    }
  },
  
  // 第 5 层：组级配置
  "group_configs": {
    "group_a": {
      "group_id": "group_a",
      "account": {
        "max_stocks": 5             // 此组最多持仓 5 只
      }
    },
    "group_b": {
      "group_id": "group_b",
      "account": {
        "max_stocks": 15            // 此组最多持仓 15 只
      }
    }
  },
  
  // ==================== 当前激活的配置层 ====================
  // 运行时会根据这些标识从各层提取配置并合并
  "active_strategy": "bollinger_conservative",
  "active_channel": "sim_channel",
  "active_account": "account_001",
  "active_group": "group_a"
}
